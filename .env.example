# ===== ОБЯЗАТЕЛЬНЫЕ ПАРАМЕТРЫ =====

# Адрес твоего кошелька CCX
WALLET=ccx7BaYihWz3LkJmDT1sx76cafd9JKVyBikc55H8jqiAWe8QVzjpxi1PGBRGjc78DU6vhuR1yXMVFDwmWM1Mj1zs46mdtNSNMy

# URL и порт пула (Conceal Network official pool)
POOL_URL=mine.conceal.network
POOL_PORT=16055

# ===== ОПЦИОНАЛЬНЫЕ =====

# Имя воркера (для идентификации на пуле, по умолчанию: hostname)
WORKER_NAME=

# Алгоритм — cn/ccx для Conceal (CCX)
ALGO=cn/ccx

# Количество потоков (по умолчанию: авто, = кол-ву CPU)
# На серверах <2GB RAM будет автоматически capped до 2
THREADS=

# TLS подключение (true/false)
TLS=false

# Пароль для пула (обычно "x")
POOL_PASS=x

# Уровень доната XMRig в процентах (0 = выкл, 1 = дефолт 1%)
DONATE=1
